generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model area {
  id                String             @id
  name              String
  korean_name       String
  bank_account_info bank_account_info?
  doc_templates     doc_template[]
}

model bank_account_info {
  area_id   String  @id(map: "bankAccountInfo_pkey")
  bank_name String?
  acc_num   String?
  area      area    @relation(fields: [area_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model doc_template {
  area_id       String
  template_id   String
  template_name String?
  id            String  @id @default(dbgenerated("(gen_random_uuid())::text"))
  area          area    @relation(fields: [area_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model message {
  id         Int       @id @default(autoincrement()) @db.SmallInt
  title      String?   @default("") @db.VarChar
  text       String?   @db.VarChar
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  edited_at  DateTime? @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String?  @db.VarChar
  name          String?  @db.VarChar
  profile_image String?  @db.VarChar
  role          String?  @db.VarChar
  created_at    DateTime @default(now()) @db.Timestamp(6)
  kakao_id      String   @unique(map: "user_kakaoId_key") @db.VarChar
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model voucher_price_info {
  id           Int     @id(map: "voucherPriceInfo_pkey") @default(autoincrement()) @db.SmallInt
  type         String?
  duration     BigInt?
  full_price   String?
  grant        String?
  actual_price String?
  year         Int

  @@unique([year, type, duration], map: "voucher_price_info_year_type_duration_uniq")
  @@index([type, duration, year])
}

model employee {
  id                      Int                 @id @db.SmallInt
  name                    String
  work_area               String[]
  phone                   String              @unique
  grade                   String
  open_to_next_work       Boolean             @default(true)
  company_registered_date DateTime?           @db.Date
  schedules_as_primary    employee_schedule[] @relation("schedule_primary_employee")
  schedules_as_secondary  employee_schedule[] @relation("schedule_secondary_employee")
}

model employee_schedule {
  id                    Int       @id @default(autoincrement())
  primary_employee_id   Int       @db.SmallInt
  work_address          String
  start_date            DateTime  @db.Date
  end_date              DateTime  @db.Date
  replaced              Boolean   @default(false)
  client_id             Int
  secondary_employee_id Int?      @db.SmallInt
  client                client    @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  primary_employee      employee  @relation("schedule_primary_employee", fields: [primary_employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  secondary_employee    employee? @relation("schedule_secondary_employee", fields: [secondary_employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model client {
  id                 Int                 @id @default(autoincrement())
  name               String
  address            String?
  phone              String?
  type               String?
  duration           Int?                @db.SmallInt
  full_price         String?
  grant              String?
  actual_price       String?
  start_date         DateTime?           @db.Date
  end_date           DateTime?           @db.Date
  care_center        Boolean
  voucher_client     Boolean
  birthday           String?             @db.VarChar(6)
  breast_pump        Boolean             @default(false)
  contract_status    String?
  e_doc_id           String?             @unique
  signed_doc         eformsign_doc?      @relation("client_signed_doc", fields: [e_doc_id], references: [document_id], onUpdate: NoAction)
  eformsign_docs     eformsign_doc[]     @relation("eformsign_doc_client")
  employee_schedules employee_schedule[]
}

model eformsign_doc {
  id                  Int      @id @default(autoincrement())
  document_id         String   @unique
  created_date        DateTime @db.Timestamptz(6)
  updated_date        DateTime @db.Timestamptz(6)
  status_type         String
  status_detail       String
  step_type           String
  step_index          String
  step_name           String
  step_recipient_type String
  step_recipient_name String
  step_recipient_sms  String
  expired_date        DateTime @db.Timestamptz(6)
  expired             Boolean  @default(false)
  client_id           Int
  signed_by_client    client?  @relation("client_signed_doc")
  client              client   @relation("eformsign_doc_client", fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model voucher_price_info_2025 {
  id           Int     @id @db.SmallInt
  type         String?
  duration     BigInt?
  full_price   String?
  grant        String?
  actual_price String?
}
