# Backend database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/babyjamjam_auth_e2e
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:55432/babyjamjam_auth_e2e

# Authentication
JWT_SECRET=replace-with-at-least-32-random-characters
AUTH_EMAIL_TOKEN_HMAC_SECRET=replace-with-a-distinct-random-secret

# Valkey primary rate-limit store
VALKEY_URL=redis://127.0.0.1:56379

# Email: use "resend" outside isolated E2E, "smtp" for Mailpit
EMAIL_TRANSPORT=smtp
SMTP_HOST=127.0.0.1
SMTP_PORT=51025
SMTP_SECURE=false
SMTP_FROM_EMAIL=admin@babyjamjam.local
RESEND_API_KEY=
RESEND_FROM_EMAIL=admin@babyjamjam.com

# Local app URLs
DEVELOPMENT_FRONTEND_URL=http://127.0.0.1:3000
DEVELOPMENT_MOBILE_FRONTEND_URL=http://127.0.0.1:3002
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4000
