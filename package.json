{
  "name": "babyjamjam-admin-workspace",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev:fe": "pnpm --filter ./frontend dev",
    "dev:be": "pnpm --filter ./backend start:dev",
    "dev:mobile": "pnpm --filter ./mobile dev",
    "build:fe": "pnpm --filter ./frontend build",
    "build:be": "pnpm --filter ./backend build",
    "build:mobile": "pnpm --filter ./mobile build",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "build": "pnpm -r --workspace-concurrency=1 build",
    "lint": "pnpm -r --workspace-concurrency=1 --if-present run lint"
  },
  "pnpm": {
    "overrides": {
      "glob": "10.5.0",
      "qs": "6.14.1",
      "lodash": "4.17.23",
      "passport-oauth2": "1.8.0",
      "tmp": "0.2.5",
      "diff": "4.0.4",
      "webpack": "5.105.0"
    },
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "@nestjs/core",
      "@parcel/watcher",
      "@swc/core",
      "sharp",
      "unrs-resolver"
    ]
  }
}
