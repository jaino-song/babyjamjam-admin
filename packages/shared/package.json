{
    "name": "@babyjamjam/shared",
    "version": "0.1.0",
    "private": true,
    "description": "Shared types, utils, and API plumbing for the babyjamjam frontend and mobile apps",
    "type": "module",
    "main": "src/index.ts",
    "types": "src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./api": "./src/api/index.ts",
        "./tokens/status-badge": "./src/tokens/status-badge.ts",
        "./ui-contracts": "./src/ui-contracts/index.ts",
        "./ui-contracts/*": "./src/ui-contracts/*.ts",
        "./types/eformsign": "./src/types/eformsign.ts",
        "./types/message": "./src/types/message.ts",
        "./types/service-record": "./src/types/service-record.ts",
        "./types/system-template": "./src/types/system-template.ts",
        "./constants/service-record-form-layout": "./src/constants/service-record-form-layout.ts",
        "./utils": "./src/utils/index.ts",
        "./eslint-plugin": "./eslint-plugin/index.mjs"
    },
    "scripts": {
        "test": "node --test eslint-plugin/__tests__/*.test.js",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "tailwind-merge": "^3.4.0",
        "zod": "^4.3.6"
    },
    "peerDependencies": {
        "next": "^16"
    },
    "devDependencies": {
        "eslint": "^9",
        "next": "16.1.6",
        "typescript": "^5"
    }
}
