{
  "version": 1,
  "updated": "2026-07-08",
  "purpose": "Machine-readable inventory of BabyJamJam design-system components. Agents MUST consult this before any UI work and compose ONLY these components in pages. See docs/design-system/AGENT_UI_RULES.md.",
  "docs": {
    "rules": "docs/design-system/AGENT_UI_RULES.md",
    "inventory": "docs/design-system/component-inventory.md",
    "designPhilosophy": "frontend/docs/design-system/README.md",
    "dataComponentConvention": "mobile/DATA-COMPONENT-CONVENTION.md"
  },
  "conventions": {
    "dataComponent": "kebab-case {page}-{parent}-{child}-{element}; enforced by data-component/require-data-component",
    "layers": {
      "atom": "direct visual-token consumers (components/ui, shadcn-based)",
      "molecule": "atom compositions: fields, badges, rows, chips",
      "organism": "workflow-level compositions: panels, tables, wizards, dialogs",
      "template": "page-level layout shells: split layouts, app frames",
      "tokens": "shared class-name/token constants — importable by design-system components only, NEVER by pages",
      "hook": "UI behavior hooks"
    },
    "pages": "src/app/**/page.tsx files assemble templates/organisms only. No local components, no style constants, no raw button/input/select/textarea/dialog, no visual Tailwind (bg-*, text-*, border-*, rounded-*, shadow-*)."
  },
