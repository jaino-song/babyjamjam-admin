      "backendModules": ["ClientModule", "EmployeeModule", "EmployeeScheduleModule", "AreaTemplateModule", "BankAccountInfoModule", "VoucherPriceInfoModule", "OutOfPocketPriceInfoModule"],
      "models": ["client", "employee", "employee_schedule", "area", "bank_account_info", "voucher_price_info", "out_of_pocket_price_info"],
      "routeFamilies": ["/clients", "/employees", "/employee-schedules", "/area-templates", "/voucher-price-infos"]
    },
    {
      "id": "documents-signatures",
      "label": "Documents and signatures",
      "backendModules": ["DocumentModule", "EformsignDocModule", "EformsignWebhookModule"],
      "models": ["doc_template", "document", "document_category", "eformsign_doc"],
      "routeFamilies": ["/documents", "/document-categories", "/eformsign-docs", "/api", "/webhooks/eformsign"]
    },
    {
