  ],
  "routeCatalog": {
    "frontend": {
      "entryAndAuth": ["/", "/login", "/callback", "/register", "/forgot-password", "/reset-password", "/verify-email", "/onboarding", "/kakao/onboarding", "/logout"],
      "protected": ["/dashboard", "/all", "/clients", "/clients/new", "/clients/filtered", "/employees", "/contracts", "/messages", "/messages/templates", "/messages/system-templates", "/consultations", "/files", "/prices", "/settings", "/settings/general", "/settings/voucher-price", "/stats", "/stats/errors", "/stats/funnel", "/stats/inquiries", "/stats/traffic", "/chat", "/admin", "/admin/feedback/[id]", "/system-admin", "/website-admin", "/select-branch"],
      "routeOwner": "frontend/src/app",
      "bffFamilies": ["auth", "clients", "employees", "documents", "eformsign", "messages", "message automation", "service records", "schedule changes", "notifications", "consultations", "files", "settings", "system admin", "AI chat"]
    },
    "mobile": {
      "entryAndAuth": ["/", "/login", "/callback", "/register", "/forgot-password", "/reset-password", "/verify-email", "/logout", "/select-branch"],
      "shell": ["/dashboard", "/dashboard/analytics", "/all", "/clients", "/clients/new", "/employees", "/employees/new", "/employees/schedule", "/contracts", "/contracts/new", "/contracts/creation", "/calls", "/messages", "/messages/new", "/messages/history", "/messages/scheduled", "/messages/automation", "/messages/sender-approval", "/messages/templates", "/messages/system-templates", "/consultations", "/files", "/files/upload", "/notification", "/notifications", "/prices", "/settings", "/chat", "/admin", "/admin/feedback", "/privacy", "/terms"],
      "public": ["/service-record/[token]"],
      "routeOwner": "mobile/src/app",
      "bffFamilies": ["auth", "clients and drafts", "employees", "documents and eformsign", "calls", "messages and automation", "service records", "schedule changes", "notifications", "consultations", "files", "settings", "system templates", "AI chat"]
    },
    "native": {
      "owners": ["native/androidApp", "native/iosApp", "native/shared"],
      "navigation": ["native/androidApp/src/main/kotlin/com/imirae/incheon/navigation/NavGraph.kt", "native/iosApp/Navigation/AppNavigation.swift"],
      "deepLinks": ["HTTPS app links", "ximae:// custom scheme"]
    },
    "backend": {
      "bootstrap": "backend/main.ts",
      "moduleRoot": "backend/app.module.ts",
      "interfaceOwner": "backend/interface/controllers",
      "families": ["auth and users", "tenant and system admin", "clients and employees", "schedules and pricing", "messages and templates", "documents and eformsign", "service records and schedule changes", "notifications", "calls and client drafts", "consultation inquiries", "AI chat"]
    }
  },
  "flows": [
    {
      "id": "auth-to-branch",
      "label": "Authenticate, establish tenant, open dashboard",
      "summary": "A browser or native client authenticates, receives server-managed session state, selects a branch, and enters a tenant-scoped shell.",
      "steps": ["desktop-admin", "desktop-bff", "backend-interface", "auth-tenant", "kakao", "auth-tenant", "postgres", "desktop-admin"],
      "criticalControls": ["rate limit", "HTTP-only session cookies on web", "refresh rotation", "active branch membership", "owner-only route guard"]
    },
    {
      "id": "client-lifecycle",
      "label": "Create and operate a client",
      "summary": "Admin surfaces submit branch-scoped client changes through BFF routes into use cases and Prisma repositories.",
      "steps": ["desktop-admin", "desktop-bff", "backend-interface", "auth-tenant", "care-operations", "clean-architecture-core", "prisma-repositories", "postgres"]
    },
    {
      "id": "contract-eformsign",
      "label": "Generate, send, and synchronize a contract",
      "summary": "Contract pages create documents, dispatch through eformsign, accept signed webhooks, project status, and stream headless progress back to clients.",
      "steps": ["mobile-admin", "mobile-bff", "backend-interface", "contracts-documents", "storage", "eformsign", "backend-interface", "postgres"]
    },
    {
      "id": "message-automation",
      "label": "Trigger and deliver an automated message",
      "summary": "Template/rule configuration persists trigger jobs; schedulers claim due work, Aligo delivers it, and logs feed history/status screens.",
      "steps": ["desktop-admin", "desktop-bff", "backend-interface", "messaging-automation", "postgres", "schedulers", "messaging-automation", "aligo", "postgres"]
    },
    {
      "id": "service-record",
      "label": "Prepare, send, complete, and finalize a service record",
      "summary": "An admin prepares a token and sends a link; the recipient completes public sessions without login; finalization materializes the record and document state.",
      "steps": ["mobile-admin", "mobile-bff", "service-record-domain", "aligo", "public-service-record", "mobile-bff", "backend-interface", "service-record-domain", "postgres", "schedulers", "contracts-documents"]
    },
    {
      "id": "schedule-change",
      "label": "Request and apply a service schedule change",
      "summary": "The public wizard previews and submits a change request; an authenticated admin approves/rejects and applies it to schedules and service-record projections.",
      "steps": ["public-service-record", "mobile-bff", "backend-interface", "service-record-domain", "postgres", "mobile-admin", "care-operations"]
    },
    {
      "id": "call-extraction",
      "label": "Ingest a call, extract facts, review a client draft",
      "summary": "Call data enters the inbox, Gemini extracts structured facts, retry schedulers recover failures, and staff confirm or discard a client draft.",
      "steps": ["mobile-admin", "mobile-bff", "backend-interface", "communications-ai", "gemini", "communications-ai", "postgres", "schedulers", "care-operations"]
    },
    {
      "id": "ai-chat",
      "label": "Stream and persist an AI operations chat",
      "summary": "Chat UI opens a streamed BFF request, backend gateways call Gemini/Vercel AI tools, and sessions/messages/feedback are persisted.",
      "steps": ["desktop-admin", "desktop-bff", "backend-interface", "communications-ai", "gemini", "communications-ai", "postgres"]
    },
    {
      "id": "notification-push",
      "label": "Create inbox notification and deliver web push",
      "summary": "Domain/background work creates notifications, schedules push delivery to stored subscriptions, and clients reconcile unread/read state.",
      "steps": ["schedulers", "platform-admin", "postgres", "web-push", "mobile-admin", "mobile-bff", "backend-interface"]
    },
    {
      "id": "file-storage",
      "label": "Upload and retrieve a managed file",
      "summary": "Admin clients proxy file operations to backend metadata services and Supabase object storage.",
      "steps": ["desktop-admin", "desktop-bff", "backend-interface", "platform-admin", "storage", "postgres"]
    }
  ],
  "agentHandoff": {
    "readOrder": [
      "docs/architecture/babyjamjam-architecture.json",
      "AGENTS.md and the relevant ~/.agents playbook domain rules",
      "the route/page named by the feature",
      "its frontend or mobile /app/api route and lib/api boundary",
      "the backend controller and feature module",
      "application service/use case",
      "domain port/entity",
      "repository/adapter and Prisma models"
    ],
    "changeMatrix": [
      { "change": "Desktop UI", "start": "frontend/src/app/(protected) or frontend/src/features", "alsoCheck": ["frontend/src/app/api", "frontend/src/lib/api", "packages/shared"] },
      { "change": "Mobile/PWA UI", "start": "mobile/src/app/(shell) or mobile/src/components", "alsoCheck": ["mobile/src/app/api", "mobile/src/middleware.ts", "packages/shared"] },
      { "change": "Public service record", "start": "mobile/src/app/(public)/service-record/[token]", "alsoCheck": ["mobile/src/app/api/service-record/[token]", "backend/interface/controllers/service-record-entry.controller.ts", "backend/module/service-record-entry.module.ts"] },
      { "change": "Backend behavior", "start": "backend/interface/controllers and backend/module", "alsoCheck": ["backend/application", "backend/domain", "backend/infrastructure", "backend/prisma/schema.prisma"] },
      { "change": "Cross-client DTO/status", "start": "packages/shared/src/types", "alsoCheck": ["frontend", "mobile", "backend"] },
      { "change": "Native behavior", "start": "native/shared/src/commonMain", "alsoCheck": ["native/androidApp", "native/iosApp", "backend interface"] },
      { "change": "Vendor integration", "start": "backend/infrastructure/api or backend/infrastructure/adapters", "alsoCheck": ["port/provider binding in backend/module", "retry/idempotency", "vendor stubs", "webhook guards"] }
    ],
    "safetyBoundaries": [
      "Do not treat frontend or mobile authorization as a security boundary; backend guards and tenant checks are authoritative.",
      "Do not expose or copy .env values into issues, logs, tests, or this map.",
      "Treat prisma/schema.prisma, dependencies, tsconfig, env files, and core auth logic as approval-required changes under the local playbook.",
      "Preserve branchId/tenant filters through controllers, services, repositories, schedulers, and vendor callbacks.",
      "Keep public service-record token flows separate from authenticated admin sessions.",
      "Vendor calls, webhooks, scheduler retries, and finalization must remain idempotent.",
      "Keep shared contract changes backward-compatible across frontend, mobile, and backend or change all consumers together."
    ],
    "verification": [
      "Run targeted tests for the changed domain first.",
      "Run the changed package lint and type-check.",
      "Run package build when defined.",
      "For UI changes, verify the actual authenticated route and rendered data-component surface.",
      "For cross-layer changes, prove the browser/native request through BFF/controller/use-case/repository or adapter.",
      "For public-token, webhook, scheduler, or vendor flows, include negative authorization and idempotency cases.",
      "Finish with the repository security-review workflow."
    ],
    "knownAmbiguities": [
      {
        "item": "frontend proxy runtime binding",
        "status": "inferred",
        "detail": "frontend/src/proxy.ts contains matcher/proxy behavior, but its effective Next.js runtime binding was not proven in this static pass."
      },
      {
        "item": "development ports",
        "status": "runtime-dependent",
        "detail": "Next.js scripts do not pin ports; local process owners and CLI overrides must be verified before browser QA. Backend main.ts binds 3001 in this snapshot."
      },
      {
        "item": "failure ordering",
        "status": "inferred",
        "detail": "Exact ordering under duplicate webhooks, vendor timeouts, and scheduler retries needs focused runtime/log verification per flow."
      }
    ]
  }
}
